{
  "name": "whiteboard-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm --prefix client run dev",
    "dev:ws": "npm --prefix server run dev",
    "dev:all": "concurrently -k \"npm run dev\" \"npm run dev:ws\"",
    "typecheck": "npx tsc -b client/tsconfig.app.json server/tsconfig.json",
    "build": "npm --prefix client run build && npm --prefix server run build",
    "ws:sim": "npm --prefix server run simulate:ws",
    "verify:ws": "npm --prefix server run verify:ws",
    "verify": "npm run typecheck && npm run build && npm run verify:ws"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
